@page "/manage/parking-condition"
@inject CurrentUserContext CurrentUserContext
@inject ParkingConditionService ParkingConditionService
@using CarPark.Models
@using CarPark.Shared.Enums

<PageTitle>จัดการเงื่อนไขจอดรถ</PageTitle>

<div class="view-head">
    <h1>จัดการเงื่อนไขจอดรถ</h1>
    <p class="view-subtitle">กำหนดประเภทสิทธิ์จอดฟรี เช่น รถเจ้าของร้าน พนักงาน รถส่งของ ฯลฯ</p>
</div>

@if (!CurrentUserContext.IsAdmin)
{
    <div class="alert alert-danger">เฉพาะผู้ดูแลระบบเท่านั้น</div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert alert-danger alert-dismissible mb-3">
            @_errorMessage
            <button type="button" class="btn-close" @onclick="ClearMessages"></button>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success alert-dismissible mb-3">
            @_successMessage
            <button type="button" class="btn-close" @onclick="ClearMessages"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="card-title mb-0">เงื่อนไขทั้งหมด</h5>
                <button class="btn btn-primary" @onclick="OpenAddModal">+ เพิ่มเงื่อนไข</button>
            </div>

            @if (_isLoading)
            {
                <p class="text-muted">กำลังโหลด...</p>
            }
            else if (_conditions.Count == 0)
            {
                <p class="text-muted">ยังไม่มีเงื่อนไข กดปุ่ม "เพิ่มเงื่อนไข" เพื่อเริ่มต้น</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ชื่อเงื่อนไข</th>
                                <th>ประเภท</th>
                                <th>รายละเอียด</th>
                                <th>ยกเว้นค้างคืน</th>
                                <th>สถานะ</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cond in _conditions)
                            {
                                <tr>
                                    <td class="fw-semibold">@cond.ConditionName</td>
                                    <td>@GetTypeName(cond.ConditionType)</td>
                                    <td class="text-muted small">@GetDetail(cond)</td>
                                    <td>
                                        @if (cond.WaiveOvernightPenalty)
                                        {
                                            <span class="badge bg-info text-dark">ยกเว้น</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">–</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @(cond.IsActive ? "bg-success" : "bg-secondary")">
                                            @(cond.IsActive ? "เปิด" : "ปิด")
                                        </span>
                                    </td>
                                    <td class="text-end" style="white-space:nowrap">
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="@(() => OpenEditModal(cond))">แก้ไข</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="@(() => DeleteAsync(cond.Id))">ลบ</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@if (_showModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editingId.HasValue ? "แก้ไขเงื่อนไข" : "เพิ่มเงื่อนไข")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">ชื่อเงื่อนไข <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="_formName" placeholder="เช่น รถเจ้าของร้านค้า, พนักงาน" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">ประเภท</label>
                            <select class="form-select" @bind="_formType">
                                <option value="@ParkingConditionType.FullyFree">ฟรีทั้งหมด</option>
                                <option value="@ParkingConditionType.FreeFirstMinutes">ฟรี N นาทีแรก</option>
                                <option value="@ParkingConditionType.QuotaFree">ฟรีตามโควต้า (คัน/วัน)</option>
                            </select>
                        </div>
                        @if (_formType == ParkingConditionType.FreeFirstMinutes)
                        {
                            <div class="col-6">
                                <label class="form-label">จำนวนนาทีที่ฟรี</label>
                                <div class="input-group">
                                    <input class="form-control" type="number" min="1" @bind="_formFreeMinutes" placeholder="60" />
                                    <span class="input-group-text">นาที</span>
                                </div>
                            </div>
                        }
                        @if (_formType == ParkingConditionType.QuotaFree)
                        {
                            <div class="col-6">
                                <label class="form-label">โควต้าต่อวัน</label>
                                <div class="input-group">
                                    <input class="form-control" type="number" min="1" @bind="_formQuotaPerDay" placeholder="10" />
                                    <span class="input-group-text">คัน/วัน</span>
                                </div>
                            </div>
                        }
                        <div class="col-12">
                            <label class="form-label">หมายเหตุ</label>
                            <input class="form-control" @bind="_formNotes" placeholder="(ไม่บังคับ)" />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" id="formWaive" @bind="_formWaiveOvernight" />
                                <label class="form-check-label" for="formWaive">ยกเว้นค่าปรับค้างคืน</label>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="formActive" @bind="_formIsActive" />
                                <label class="form-check-label" for="formActive">เปิดใช้งาน</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">ยกเลิก</button>
                    <button class="btn btn-primary" @onclick="SaveModalAsync">
                        @(_editingId.HasValue ? "บันทึกการแก้ไข" : "เพิ่มเงื่อนไข")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ParkingCondition> _conditions = [];
    private bool _isLoading = true;
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;

    private bool _showModal;
    private Guid? _editingId;
    private string _formName = string.Empty;
    private ParkingConditionType _formType = ParkingConditionType.FullyFree;
    private int? _formFreeMinutes;
    private int? _formQuotaPerDay;
    private bool _formWaiveOvernight;
    private bool _formIsActive = true;
    private string _formNotes = string.Empty;

    protected override async Task OnInitializedAsync() => await LoadDataAsync();

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _conditions = await ParkingConditionService.GetAllAsync();
        _isLoading = false;
    }

    private void OpenAddModal()
    {
        ClearMessages();
        _editingId = null;
        _formName = string.Empty;
        _formType = ParkingConditionType.FullyFree;
        _formFreeMinutes = null;
        _formQuotaPerDay = null;
        _formWaiveOvernight = false;
        _formIsActive = true;
        _formNotes = string.Empty;
        _showModal = true;
    }

    private void OpenEditModal(ParkingCondition cond)
    {
        ClearMessages();
        _editingId = cond.Id;
        _formName = cond.ConditionName;
        _formType = cond.ConditionType;
        _formFreeMinutes = cond.FreeMinutes;
        _formQuotaPerDay = cond.QuotaPerDay;
        _formWaiveOvernight = cond.WaiveOvernightPenalty;
        _formIsActive = cond.IsActive;
        _formNotes = cond.Notes ?? string.Empty;
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private async Task SaveModalAsync()
    {
        ClearMessages();
        if (string.IsNullOrWhiteSpace(_formName)) { _errorMessage = "กรุณากรอกชื่อเงื่อนไข"; return; }
        try
        {
            var entity = new ParkingCondition
            {
                Id = _editingId ?? Guid.Empty,
                ConditionName = _formName.Trim(),
                ConditionType = _formType,
                FreeMinutes = _formType == ParkingConditionType.FreeFirstMinutes ? _formFreeMinutes : null,
                QuotaPerDay = _formType == ParkingConditionType.QuotaFree ? _formQuotaPerDay : null,
                WaiveOvernightPenalty = _formWaiveOvernight,
                Notes = string.IsNullOrWhiteSpace(_formNotes) ? null : _formNotes.Trim(),
                IsActive = _formIsActive
            };

            if (_editingId.HasValue)
            {
                await ParkingConditionService.UpdateAsync(entity);
                _successMessage = "แก้ไขเงื่อนไขสำเร็จ";
            }
            else
            {
                await ParkingConditionService.CreateAsync(entity);
                _successMessage = "เพิ่มเงื่อนไขสำเร็จ";
            }
            CloseModal();
            await LoadDataAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    private async Task DeleteAsync(Guid id)
    {
        ClearMessages();
        try
        {
            await ParkingConditionService.DeleteAsync(id);
            _successMessage = "ลบเงื่อนไขสำเร็จ";
            await LoadDataAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    private static string GetTypeName(ParkingConditionType type) => type switch
    {
        ParkingConditionType.FullyFree => "ฟรีทั้งหมด",
        ParkingConditionType.FreeFirstMinutes => "ฟรี N นาทีแรก",
        ParkingConditionType.QuotaFree => "ฟรีตามโควต้า",
        _ => "-"
    };

    private static string GetDetail(ParkingCondition cond) => cond.ConditionType switch
    {
        ParkingConditionType.FreeFirstMinutes => cond.FreeMinutes.HasValue ? $"ฟรี {cond.FreeMinutes} นาทีแรก" : "-",
        ParkingConditionType.QuotaFree => cond.QuotaPerDay.HasValue ? $"{cond.QuotaPerDay} คัน/วัน" : "-",
        _ => "-"
    };

    private void ClearMessages() { _errorMessage = string.Empty; _successMessage = string.Empty; }
}
