@page "/manage/parking-lot/{ParkingLotId:guid}/rate-rules"
@inject CurrentUserContext CurrentUserContext
@inject ParkingRateRuleService ParkingRateRuleService

<PageTitle>จัดการอัตราค่าบริการ</PageTitle>

<div class="view-head">
    <h1>จัดการอัตราค่าบริการ</h1>
    <p class="view-subtitle">กำหนดขั้นบันไดค่าบริการ ค่าปรับ และเงื่อนไขสำหรับลานจอดรถ</p>
</div>

@if (!CurrentUserContext.IsAdmin)
{
    <div class="alert alert-danger" role="alert">
        ไม่มีสิทธิ์เข้าใช้งาน หน้านี้สำหรับผู้ดูแลระบบเท่านั้น
    </div>
}
else if (!_isLotLoaded)
{
    <p>กำลังโหลด...</p>
}
else if (_lot is null)
{
    <div class="alert alert-danger" role="alert">
        ไม่พบลานจอดรถ
    </div>
    <a class="btn btn-secondary" href="/manage/parking-lot">กลับสู่รายการลานจอดรถ</a>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="card-title mb-1">@_lot.LotCode - @_lot.LotName</h5>
                    <small class="text-muted">รายละเอียดอัตราค่าบริการสำหรับลานจอดรถที่เลือก</small>
                </div>
                <a class="btn btn-outline-secondary" href="/manage/parking-lot">กลับสู่รายการลานจอดรถ</a>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">เพิ่มอัตราค่าบริการ</h5>

            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label">ชื่อกฎ</label>
                    <input class="form-control" @bind="_newRuleName" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">ลำดับ</label>
                    <input class="form-control" type="number" min="1" @bind="_newSequence" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">นาทีเริ่มต้น</label>
                    <input class="form-control" type="number" min="0" @bind="_newStartMinute" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">นาทีสิ้นสุด</label>
                    <input class="form-control" type="number" min="0" @bind="_newEndMinuteText" placeholder="ว่าง = ไม่จำกัด" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">จำนวนเงิน</label>
                    <input class="form-control" type="number" min="0" step="0.01" @bind="_newAmount" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">ประเภทการคำนวณ</label>
                    <select class="form-select" @bind="_newCalculationType">
                        @foreach (var type in _calculationTypes)
                        {
                            <option value="@type">@GetCalculationTypeLabel(type)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">ขั้นการเรียกเก็บ (นาที)</label>
                    <input class="form-control" type="number" min="1" @bind="_newBillingStepMinutesText" placeholder="ว่าง = ไม่ใช้งาน" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="newOvernight" @bind="_newApplyOnOvernight" />
                        <label class="form-check-label" for="newOvernight">ค้างคืน</label>
                    </div>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="newActive" @bind="_newIsActive" />
                        <label class="form-check-label" for="newActive">ใช้งาน</label>
                    </div>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary w-100" @onclick="AddRuleAsync">เพิ่มกฎ</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h5 class="card-title">รายการอัตราค่าบริการ</h5>

            @if (_isLoading)
            {
                <p>กำลังโหลด...</p>
            }
            else if (_rules.Count == 0)
            {
                <p>ไม่พบอัตราค่าบริการสำหรับลานจอดรถนี้</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>ชื่อกฎ</th>
                                <th>ลำดับ</th>
                                <th>เริ่ม</th>
                                <th>สิ้นสุด</th>
                                <th>ประเภท</th>
                                <th>จำนวนเงิน</th>
                                <th>ขั้น</th>
                                <th>ค้างคืน</th>
                                <th>ใช้งาน</th>
                                <th class="text-end">จัดการ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rule in _rules)
                            {
                                <tr>
                                    @if (_editingRuleId == rule.Id)
                                    {
                                        <td><input class="form-control" @bind="_editRuleName" /></td>
                                        <td><input class="form-control" type="number" min="1" @bind="_editSequence" /></td>
                                        <td><input class="form-control" type="number" min="0" @bind="_editStartMinute" /></td>
                                        <td><input class="form-control" type="number" min="0" @bind="_editEndMinuteText" /></td>
                                        <td>
                                            <select class="form-select" @bind="_editCalculationType">
                                                @foreach (var type in _calculationTypes)
                                                {
                                                    <option value="@type">@GetCalculationTypeLabel(type)</option>
                                                }
                                            </select>
                                        </td>
                                        <td><input class="form-control" type="number" min="0" step="0.01" @bind="_editAmount" /></td>
                                        <td><input class="form-control" type="number" min="1" @bind="_editBillingStepMinutesText" /></td>
                                        <td><input class="form-check-input" type="checkbox" @bind="_editApplyOnOvernight" /></td>
                                        <td><input class="form-check-input" type="checkbox" @bind="_editIsActive" /></td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-success me-2" @onclick="SaveEditAsync">บันทึก</button>
                                            <button class="btn btn-sm btn-secondary" @onclick="CancelEdit">ยกเลิก</button>
                                        </td>
                                    }
                                    else
                                    {
                                        <td>@rule.RuleName</td>
                                        <td>@rule.Sequence</td>
                                        <td>@rule.StartMinute</td>
                                        <td>@(rule.EndMinute?.ToString() ?? "-")</td>
                                        <td>@GetCalculationTypeLabel(rule.CalculationType)</td>
                                        <td>@rule.Amount</td>
                                        <td>@(rule.BillingStepMinutes?.ToString() ?? "-")</td>
                                        <td>@(rule.ApplyOnOvernight ? "ใช่" : "ไม่")</td>
                                        <td>@(rule.IsActive ? "ใช่" : "ไม่")</td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-primary me-2" @onclick="@(() => StartEdit(rule))">แก้ไข</button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="@(() => DeleteRuleAsync(rule.Id))">ลบ</button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert alert-danger mt-3" role="alert">@_errorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success mt-3" role="alert">@_successMessage</div>
    }
}

@code {
    [Parameter]
    public Guid ParkingLotId { get; set; }

    private ParkingLot? _lot;
    private readonly List<ParkingRateRule> _rules = [];
    private readonly ParkingRateCalculationType[] _calculationTypes = Enum.GetValues<ParkingRateCalculationType>();

    private bool _isLoading = true;
    private bool _isLotLoaded;

    private string _newRuleName = string.Empty;
    private int _newSequence = 1;
    private int _newStartMinute;
    private string _newEndMinuteText = string.Empty;
    private ParkingRateCalculationType _newCalculationType = ParkingRateCalculationType.Free;
    private decimal _newAmount;
    private string _newBillingStepMinutesText = string.Empty;
    private bool _newApplyOnOvernight;
    private bool _newIsActive = true;

    private Guid? _editingRuleId;
    private string _editRuleName = string.Empty;
    private int _editSequence = 1;
    private int _editStartMinute;
    private string _editEndMinuteText = string.Empty;
    private ParkingRateCalculationType _editCalculationType = ParkingRateCalculationType.Free;
    private decimal _editAmount;
    private string _editBillingStepMinutesText = string.Empty;
    private bool _editApplyOnOvernight;
    private bool _editIsActive = true;

    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (!CurrentUserContext.IsAdmin)
        {
            _isLotLoaded = true;
            _isLoading = false;
            return;
        }

        ClearMessages();
        _isLoading = true;
        _isLotLoaded = false;

        try
        {
            _lot = await ParkingRateRuleService.GetParkingLotByIdAsync(ParkingLotId);
            _isLotLoaded = true;

            if (_lot is not null)
            {
                await LoadRulesAsync();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _isLotLoaded = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadRulesAsync()
    {
        _isLoading = true;

        try
        {
            _rules.Clear();
            _rules.AddRange(await ParkingRateRuleService.GetRulesByLotAsync(ParkingLotId));
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task AddRuleAsync()
    {
        ClearMessages();

        if (!TryBuildRuleInput(
            _newRuleName,
            _newSequence,
            _newStartMinute,
            _newEndMinuteText,
            _newCalculationType,
            _newAmount,
            _newBillingStepMinutesText,
            _newApplyOnOvernight,
            _newIsActive,
            out var rule))
        {
            return;
        }

        rule.ParkingLotId = ParkingLotId;

        try
        {
            await ParkingRateRuleService.CreateAsync(rule);
            ResetNewForm();
            _successMessage = "เพิ่มอัตราค่าบริการสำเร็จ";
            await LoadRulesAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void StartEdit(ParkingRateRule rule)
    {
        ClearMessages();
        _editingRuleId = rule.Id;
        _editRuleName = rule.RuleName;
        _editSequence = rule.Sequence;
        _editStartMinute = rule.StartMinute;
        _editEndMinuteText = rule.EndMinute?.ToString() ?? string.Empty;
        _editCalculationType = rule.CalculationType;
        _editAmount = rule.Amount;
        _editBillingStepMinutesText = rule.BillingStepMinutes?.ToString() ?? string.Empty;
        _editApplyOnOvernight = rule.ApplyOnOvernight;
        _editIsActive = rule.IsActive;
    }

    private void CancelEdit()
    {
        _editingRuleId = null;
        _editRuleName = string.Empty;
        _editSequence = 1;
        _editStartMinute = 0;
        _editEndMinuteText = string.Empty;
        _editCalculationType = ParkingRateCalculationType.Free;
        _editAmount = 0;
        _editBillingStepMinutesText = string.Empty;
        _editApplyOnOvernight = false;
        _editIsActive = true;
    }

    private async Task SaveEditAsync()
    {
        ClearMessages();

        if (!_editingRuleId.HasValue)
        {
            return;
        }

        if (!TryBuildRuleInput(
            _editRuleName,
            _editSequence,
            _editStartMinute,
            _editEndMinuteText,
            _editCalculationType,
            _editAmount,
            _editBillingStepMinutesText,
            _editApplyOnOvernight,
            _editIsActive,
            out var rule))
        {
            return;
        }

        rule.Id = _editingRuleId.Value;
        rule.ParkingLotId = ParkingLotId;

        try
        {
            await ParkingRateRuleService.UpdateAsync(rule);
            _successMessage = "แก้ไขอัตราค่าบริการสำเร็จ";
            CancelEdit();
            await LoadRulesAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task DeleteRuleAsync(Guid id)
    {
        ClearMessages();

        try
        {
            await ParkingRateRuleService.DeleteAsync(id);
            _successMessage = "ลบอัตราค่าบริการสำเร็จ";
            await LoadRulesAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private bool TryBuildRuleInput(
        string ruleName,
        int sequence,
        int startMinute,
        string endMinuteText,
        ParkingRateCalculationType calculationType,
        decimal amount,
        string billingStepMinutesText,
        bool applyOnOvernight,
        bool isActive,
        out ParkingRateRule rule)
    {
        rule = new ParkingRateRule();

        if (string.IsNullOrWhiteSpace(ruleName))
        {
            _errorMessage = "กรุณากรอกชื่อกฎ";
            return false;
        }

        if (sequence <= 0)
        {
            _errorMessage = "ลำดับต้องมากกว่า 0";
            return false;
        }

        if (startMinute < 0)
        {
            _errorMessage = "นาทีเริ่มต้นต้องเป็น 0 หรือมากกว่า";
            return false;
        }

        if (amount < 0)
        {
            _errorMessage = "จำนวนเงินต้องเป็น 0 หรือมากกว่า";
            return false;
        }

        if (!TryParseNullableInt(endMinuteText, out var endMinute))
        {
            _errorMessage = "นาทีสิ้นสุดไม่ถูกต้อง";
            return false;
        }

        if (!TryParseNullableInt(billingStepMinutesText, out var billingStepMinutes))
        {
            _errorMessage = "ขั้นการเรียกเก็บ (นาที) ไม่ถูกต้อง";
            return false;
        }

        if (endMinute.HasValue && endMinute.Value < startMinute)
        {
            _errorMessage = "นาทีสิ้นสุดต้องมากกว่าหรือเท่ากับนาทีเริ่มต้น";
            return false;
        }

        if (billingStepMinutes.HasValue && billingStepMinutes.Value <= 0)
        {
            _errorMessage = "ขั้นการเรียกเก็บ (นาที) ต้องมากกว่า 0";
            return false;
        }

        rule = new ParkingRateRule
        {
            RuleName = ruleName,
            Sequence = sequence,
            StartMinute = startMinute,
            EndMinute = endMinute,
            CalculationType = calculationType,
            Amount = amount,
            BillingStepMinutes = billingStepMinutes,
            ApplyOnOvernight = applyOnOvernight,
            IsActive = isActive
        };

        return true;
    }

    private static bool TryParseNullableInt(string input, out int? value)
    {
        value = null;

        if (string.IsNullOrWhiteSpace(input))
        {
            return true;
        }

        if (int.TryParse(input, out var parsed))
        {
            value = parsed;
            return true;
        }

        return false;
    }

    private void ResetNewForm()
    {
        _newRuleName = string.Empty;
        _newSequence = _rules.Count + 1;
        _newStartMinute = 0;
        _newEndMinuteText = string.Empty;
        _newCalculationType = ParkingRateCalculationType.Free;
        _newAmount = 0;
        _newBillingStepMinutesText = string.Empty;
        _newApplyOnOvernight = false;
        _newIsActive = true;
    }

    private static string GetCalculationTypeLabel(ParkingRateCalculationType type) => type switch
    {
        ParkingRateCalculationType.Free => "ฟรี",
        ParkingRateCalculationType.PerHour => "รายชั่วโมง",
        ParkingRateCalculationType.FlatAmount => "อัตราคงที่",
        ParkingRateCalculationType.OvernightPenalty => "ค่าปรับค้างคืน",
        _ => type.ToString()
    };

    private void ClearMessages()
    {
        _errorMessage = string.Empty;
        _successMessage = string.Empty;
    }
}
