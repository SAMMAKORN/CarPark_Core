@page "/manage/parking-lot/{ParkingLotId:guid}/rate-rules"
@page "/manage/parking-lot/{ParkingLotId:guid}/schedules/{ScheduleId:guid}/rate-rules"
@inject CurrentUserContext CurrentUserContext
@inject ParkingRateRuleService ParkingRateRuleService
@inject ParkingLotService ParkingLotService
@inject ParkingLotScheduleService ScheduleService
@using CarPark.Shared.Enums

<PageTitle>จัดการอัตราค่าบริการ</PageTitle>

<div class="view-head">
    <h1>จัดการอัตราค่าบริการ</h1>
    <p class="view-subtitle">กำหนดขั้นบันไดค่าบริการและเงื่อนไขสำหรับลานจอดรถ</p>
</div>

@if (!CurrentUserContext.IsAdmin)
{
    <div class="alert alert-danger">ไม่มีสิทธิ์เข้าใช้งาน หน้านี้สำหรับผู้ดูแลระบบเท่านั้น</div>
}
else if (!_isLotLoaded)
{
    <p class="text-muted">กำลังโหลด...</p>
}
else if (_lot is null)
{
    <div class="alert alert-danger">ไม่พบลานจอดรถ</div>
    <a class="btn btn-secondary" href="/manage/parking-lot">กลับสู่รายการลาน</a>
}
else
{
    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert alert-danger alert-dismissible mb-3">
            @_errorMessage
            <button type="button" class="btn-close" @onclick="ClearMessages"></button>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success alert-dismissible mb-3">
            @_successMessage
            <button type="button" class="btn-close" @onclick="ClearMessages"></button>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h5 class="card-title mb-1">@_lot.LotName</h5>
                @if (_schedule is not null)
                {
                    <span class="badge bg-primary">
                        ตารางเวลา: @_schedule.ScheduleName
                        (@ParkingLotScheduleService.GetDayNames((CarPark.Shared.Enums.WeekDays)_schedule.DaysOfWeek))
                    </span>
                }
                else
                {
                    <small class="text-muted">อัตราค่าบริการทั่วไป (วันที่ไม่มีตารางเวลาเฉพาะ)</small>
                }
            </div>
            <div class="d-flex gap-2">
                <a class="btn btn-outline-dark btn-sm" href="@($"/manage/parking-lot/{ParkingLotId}/schedules")">ตารางเวลา</a>
                <a class="btn btn-outline-secondary btn-sm" href="/manage/parking-lot">รายการลาน</a>
            </div>
        </div>
    </div>

    @if (_otherLots.Count > 0)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">คัดลอกอัตราค่าบริการจากลานอื่น</h5>
                <p class="text-muted small mb-2">คัดลอกกฎทั้งหมดจากลานที่เลือก โดยต่อท้ายจากลำดับที่มีอยู่</p>
                <div class="row g-2 align-items-end">
                    <div class="col-sm-7">
                        <label class="form-label">เลือกลานต้นทาง</label>
                        <select class="form-select" @bind="_copySourceLotId">
                            <option value="">-- เลือกลาน --</option>
                            @foreach (var lot in _otherLots)
                            {
                                <option value="@lot.Id">@lot.LotName</option>
                            }
                        </select>
                    </div>
                    <div class="col-sm-3">
                        <button class="btn btn-outline-secondary w-100" @onclick="CopyRulesAsync"
                                disabled="@string.IsNullOrWhiteSpace(_copySourceLotId)">
                            คัดลอกกฎ
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h5 class="card-title mb-0">รายการอัตราค่าบริการ</h5>
                    <small class="text-muted">กฎจะตรวจสอบตามลำดับ — ลำดับแรกที่ตรงเงื่อนไขจะถูกใช้</small>
                </div>
                <button class="btn btn-primary" @onclick="OpenAddModal">+ เพิ่มกฎ</button>
            </div>

            @if (_isLoading)
            {
                <p class="text-muted">กำลังโหลด...</p>
            }
            else if (_rules.Count == 0)
            {
                <p class="text-muted">ยังไม่มีอัตราค่าบริการ</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:3rem">#</th>
                                <th>ชื่อกฎ</th>
                                <th>ช่วงนาที</th>
                                <th>ประเภท</th>
                                <th class="text-end">จำนวนเงิน</th>
                                <th>ขั้น (นาที)</th>
                                <th>สถานะ</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rule in _rules)
                            {
                                <tr>
                                    <td class="text-muted">@rule.Sequence</td>
                                    <td class="fw-semibold">@rule.RuleName</td>
                                    <td class="small">
                                        @rule.StartMinute –
                                        @(rule.EndMinute.HasValue ? rule.EndMinute.Value.ToString() : "∞")
                                        <span class="text-muted">นาที</span>
                                    </td>
                                    <td><span class="badge bg-light text-dark border">@GetCalcLabel(rule.CalculationType)</span></td>
                                    <td class="text-end fw-semibold">@rule.Amount.ToString("N2")</td>
                                    <td class="text-muted small">@(rule.BillingStepMinutes.HasValue ? $"{rule.BillingStepMinutes} นาที" : "–")</td>
                                    <td>
                                        <span class="badge @(rule.IsActive ? "bg-success" : "bg-secondary")">
                                            @(rule.IsActive ? "ใช้งาน" : "ปิด")
                                        </span>
                                    </td>
                                    <td class="text-end" style="white-space:nowrap">
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="@(() => OpenEditModal(rule))">แก้ไข</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="@(() => DeleteRuleAsync(rule.Id))">ลบ</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@if (_showModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editingId.HasValue ? "แก้ไขกฎ" : "เพิ่มกฎ")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-8">
                            <label class="form-label">ชื่อกฎ <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="_formRuleName" placeholder="เช่น 0-30 นาทีแรก" />
                        </div>
                        <div class="col-4">
                            <label class="form-label">ลำดับ</label>
                            <input class="form-control" type="number" min="1" @bind="_formSequence" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">นาทีเริ่มต้น</label>
                            <div class="input-group">
                                <input class="form-control" type="number" min="0" @bind="_formStartMinute" />
                                <span class="input-group-text">นาที</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <label class="form-label">นาทีสิ้นสุด <span class="text-muted small">(ว่าง = ไม่จำกัด)</span></label>
                            <div class="input-group">
                                <input class="form-control" type="number" min="0" @bind="_formEndMinuteText" placeholder="∞" />
                                <span class="input-group-text">นาที</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <label class="form-label">ประเภทการคำนวณ</label>
                            <select class="form-select" @bind="_formCalculationType">
                                @foreach (var t in _calculationTypes)
                                {
                                    <option value="@t">@GetCalcLabel(t)</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label">จำนวนเงิน (บาท)</label>
                            <input class="form-control" type="number" min="0" step="0.01" @bind="_formAmount" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">ขั้นการเรียกเก็บ <span class="text-muted small">(ว่าง = ไม่ใช้)</span></label>
                            <div class="input-group">
                                <input class="form-control" type="number" min="1" @bind="_formBillingStepText" placeholder="60" />
                                <span class="input-group-text">นาที</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="formActive" @bind="_formIsActive" />
                                <label class="form-check-label" for="formActive">เปิดใช้งาน</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">ยกเลิก</button>
                    <button class="btn btn-primary" @onclick="SaveModalAsync">
                        @(_editingId.HasValue ? "บันทึกการแก้ไข" : "เพิ่มกฎ")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid ParkingLotId { get; set; }
    [Parameter] public Guid? ScheduleId { get; set; }

    private ParkingLot? _lot;
    private ParkingLotSchedule? _schedule;
    private readonly List<ParkingRateRule> _rules = [];
    private List<ParkingLot> _otherLots = [];
    private string _copySourceLotId = string.Empty;
    private readonly ParkingRateCalculationType[] _calculationTypes = Enum.GetValues<ParkingRateCalculationType>();

    private bool _isLoading = true;
    private bool _isLotLoaded;
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;

    private bool _showModal;
    private Guid? _editingId;
    private string _formRuleName = string.Empty;
    private int _formSequence = 1;
    private int _formStartMinute;
    private string _formEndMinuteText = string.Empty;
    private ParkingRateCalculationType _formCalculationType = ParkingRateCalculationType.Free;
    private decimal _formAmount;
    private string _formBillingStepText = string.Empty;
    private bool _formIsActive = true;

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        if (!CurrentUserContext.IsAdmin) { _isLotLoaded = true; _isLoading = false; return; }
        ClearMessages();
        _isLoading = true; _isLotLoaded = false;
        try
        {
            _lot = await ParkingRateRuleService.GetParkingLotByIdAsync(ParkingLotId);
            _isLotLoaded = true;
            if (_lot is not null)
            {
                var allLots = await ParkingLotService.GetAllAsync();
                _otherLots = allLots.Where(x => x.Id != ParkingLotId).ToList();
                if (ScheduleId.HasValue)
                    _schedule = await ScheduleService.GetByIdAsync(ScheduleId.Value);
                await LoadRulesAsync();
            }
        }
        catch (Exception ex) { _errorMessage = ex.Message; _isLotLoaded = true; }
        finally { _isLoading = false; }
    }

    private async Task LoadRulesAsync()
    {
        _isLoading = true;
        try
        {
            _rules.Clear();
            _rules.AddRange(await ParkingRateRuleService.GetRulesByLotAsync(ParkingLotId, ScheduleId));
            _formSequence = GetNextSequence();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _isLoading = false; }
    }

    private async Task CopyRulesAsync()
    {
        ClearMessages();
        if (!Guid.TryParse(_copySourceLotId, out var srcId)) { _errorMessage = "กรุณาเลือกลานต้นทาง"; return; }
        try
        {
            await ParkingRateRuleService.CopyRulesFromLotAsync(srcId, ParkingLotId);
            _copySourceLotId = string.Empty;
            _successMessage = "คัดลอกอัตราค่าบริการสำเร็จ";
            await LoadRulesAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    private void OpenAddModal()
    {
        ClearMessages();
        _editingId = null;
        _formRuleName = string.Empty;
        _formSequence = GetNextSequence();
        _formStartMinute = 0;
        _formEndMinuteText = string.Empty;
        _formCalculationType = ParkingRateCalculationType.Free;
        _formAmount = 0;
        _formBillingStepText = string.Empty;
        _formIsActive = true;
        _showModal = true;
    }

    private void OpenEditModal(ParkingRateRule rule)
    {
        ClearMessages();
        _editingId = rule.Id;
        _formRuleName = rule.RuleName;
        _formSequence = rule.Sequence;
        _formStartMinute = rule.StartMinute;
        _formEndMinuteText = rule.EndMinute?.ToString() ?? string.Empty;
        _formCalculationType = rule.CalculationType;
        _formAmount = rule.Amount;
        _formBillingStepText = rule.BillingStepMinutes?.ToString() ?? string.Empty;
        _formIsActive = rule.IsActive;
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private async Task SaveModalAsync()
    {
        ClearMessages();
        if (string.IsNullOrWhiteSpace(_formRuleName)) { _errorMessage = "กรุณากรอกชื่อกฎ"; return; }
        if (_formSequence <= 0) { _errorMessage = "ลำดับต้องมากกว่า 0"; return; }
        if (_formStartMinute < 0) { _errorMessage = "นาทีเริ่มต้นต้องเป็น 0 หรือมากกว่า"; return; }
        if (_formAmount < 0) { _errorMessage = "จำนวนเงินต้องเป็น 0 หรือมากกว่า"; return; }
        if (!TryParseNullableInt(_formEndMinuteText, out var endMinute)) { _errorMessage = "นาทีสิ้นสุดไม่ถูกต้อง"; return; }
        if (!TryParseNullableInt(_formBillingStepText, out var billingStep)) { _errorMessage = "ขั้นการเรียกเก็บไม่ถูกต้อง"; return; }
        if (endMinute.HasValue && endMinute.Value < _formStartMinute) { _errorMessage = "นาทีสิ้นสุดต้องมากกว่าหรือเท่ากับนาทีเริ่มต้น"; return; }
        if (billingStep.HasValue && billingStep.Value <= 0) { _errorMessage = "ขั้นการเรียกเก็บต้องมากกว่า 0"; return; }

        var rule = new ParkingRateRule
        {
            Id = _editingId ?? Guid.Empty,
            ParkingLotId = ParkingLotId,
            ParkingScheduleId = ScheduleId,
            RuleName = _formRuleName.Trim(),
            Sequence = _formSequence,
            StartMinute = _formStartMinute,
            EndMinute = endMinute,
            CalculationType = _formCalculationType,
            Amount = _formAmount,
            BillingStepMinutes = billingStep,
            IsActive = _formIsActive
        };

        try
        {
            if (_editingId.HasValue)
            {
                await ParkingRateRuleService.UpdateAsync(rule);
                _successMessage = "แก้ไขอัตราค่าบริการสำเร็จ";
            }
            else
            {
                await ParkingRateRuleService.CreateAsync(rule);
                _successMessage = "เพิ่มอัตราค่าบริการสำเร็จ";
            }
            CloseModal();
            await LoadRulesAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    private async Task DeleteRuleAsync(Guid id)
    {
        ClearMessages();
        try
        {
            await ParkingRateRuleService.DeleteAsync(id);
            _successMessage = "ลบอัตราค่าบริการสำเร็จ";
            await LoadRulesAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    private static bool TryParseNullableInt(string input, out int? value)
    {
        value = null;
        if (string.IsNullOrWhiteSpace(input)) return true;
        if (int.TryParse(input, out var parsed)) { value = parsed; return true; }
        return false;
    }

    private int GetNextSequence() => _rules.Count == 0 ? 1 : _rules.Max(x => x.Sequence) + 1;

    private static string GetCalcLabel(ParkingRateCalculationType type) => type switch
    {
        ParkingRateCalculationType.Free => "ฟรี",
        ParkingRateCalculationType.PerHour => "รายชั่วโมง",
        ParkingRateCalculationType.FlatAmount => "อัตราคงที่",
        _ => type.ToString()
    };

    private void ClearMessages() { _errorMessage = string.Empty; _successMessage = string.Empty; }
}
