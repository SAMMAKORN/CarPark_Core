@page "/manage/parking-lot/{ParkingLotId:guid}/schedules"
@inject CurrentUserContext CurrentUserContext
@inject ParkingLotScheduleService ScheduleService
@inject ParkingLotService ParkingLotService

<PageTitle>ตารางเวลา</PageTitle>

<div class="view-head">
    <h1>ตารางเวลา</h1>
    <p class="view-subtitle">กำหนดช่วงวัน เวลาทำการ และอัตราค่าบริการตามประเภทวัน</p>
</div>

@if (!CurrentUserContext.IsAdmin)
{
    <div class="alert alert-danger">ไม่มีสิทธิ์เข้าใช้งาน</div>
}
else if (!_isLotLoaded)
{
    <p class="text-muted">กำลังโหลด...</p>
}
else if (_lot is null)
{
    <div class="alert alert-danger">ไม่พบลานจอดรถ</div>
    <a class="btn btn-secondary" href="/manage/parking-lot">กลับสู่รายการลาน</a>
}
else
{
    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert alert-danger alert-dismissible mb-3">
            @_errorMessage
            <button type="button" class="btn-close" @onclick="ClearMessages"></button>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success alert-dismissible mb-3">
            @_successMessage
            <button type="button" class="btn-close" @onclick="ClearMessages"></button>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h5 class="card-title mb-1">@_lot.LotName</h5>
                <small class="text-muted">วันที่ไม่ได้ระบุจะใช้อัตราทั่วไปของลาน</small>
            </div>
            <div class="d-flex gap-2">
                <a class="btn btn-outline-dark btn-sm" href="@($"/manage/parking-lot/{ParkingLotId}/rate-rules")">อัตราค่าบริการทั่วไป</a>
                <a class="btn btn-outline-secondary btn-sm" href="/manage/parking-lot">รายการลาน</a>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="card-title mb-0">รายการตารางเวลา</h5>
                <button class="btn btn-primary" @onclick="OpenAddModal">+ เพิ่มตารางเวลา</button>
            </div>

            @if (_isLoading)
            {
                <p class="text-muted">กำลังโหลด...</p>
            }
            else if (_schedules.Count == 0)
            {
                <p class="text-muted">ยังไม่มีตารางเวลา — ใช้อัตราค่าบริการทั่วไปของลานทุกวัน</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ชื่อ</th>
                                <th>วันที่ใช้งาน</th>
                                <th>เวลาทำการ</th>
                                <th>สถานะ</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _schedules)
                            {
                                <tr>
                                    <td class="fw-semibold">@s.ScheduleName</td>
                                    <td class="small text-muted">@ParkingLotScheduleService.GetDayNames((CarPark.Shared.Enums.WeekDays)s.DaysOfWeek)</td>
                                    <td>
                                        @if (s.IsAllDay)
                                        {
                                            <span class="badge bg-info text-dark">ตลอดเวลา</span>
                                        }
                                        else
                                        {
                                            <div class="small">
                                                <div>@s.OpenTime.ToString(@"hh\:mm") – @s.CloseTime.ToString(@"hh\:mm")</div>
                                                @if (s.BillingStartTime.HasValue && s.BillingEndTime.HasValue)
                                                {
                                                    <div class="text-muted">เก็บค่า @s.BillingStartTime.Value.ToString(@"hh\:mm") – @s.BillingEndTime.Value.ToString(@"hh\:mm")</div>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">
                                            @(s.IsActive ? "ใช้งาน" : "ปิด")
                                        </span>
                                    </td>
                                    <td class="text-end" style="white-space:nowrap">
                                        <a class="btn btn-sm btn-outline-dark me-1"
                                           href="@($"/manage/parking-lot/{ParkingLotId}/schedules/{s.Id}/rate-rules")">
                                            อัตราค่าบริการ
                                        </a>
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="@(() => OpenEditModal(s))">แก้ไข</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="@(() => DeleteAsync(s.Id))">ลบ</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@if (_showModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editingId.HasValue ? "แก้ไขตารางเวลา" : "เพิ่มตารางเวลา")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">ชื่อตารางเวลา <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="_formName" placeholder="เช่น วันธรรมดา, วันหยุด" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">วันที่ใช้งาน</label>
                            <div class="d-flex gap-3 flex-wrap mt-1">
                                @foreach (var (bit, label) in _dayOptions)
                                {
                                    var b = bit;
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="day_@b"
                                               checked="@((_formDays & b) != 0)"
                                               @onchange="e => ToggleDay(b, (bool)(e.Value ?? false))" />
                                        <label class="form-check-label" for="day_@b">@label</label>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="formAllDay" @bind="_formIsAllDay" />
                                <label class="form-check-label" for="formAllDay">เปิดตลอดเวลา (24 ชม.)</label>
                            </div>
                        </div>
                        @if (!_formIsAllDay)
                        {
                            <div class="col-6">
                                <label class="form-label">เวลาเปิด</label>
                                <input class="form-control" type="time" lang="en-GB" @bind="_formOpenTime" @bind:format="HH:mm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">เวลาปิด</label>
                                <input class="form-control" type="time" lang="en-GB" @bind="_formCloseTime" @bind:format="HH:mm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">เริ่มเก็บค่า <span class="text-muted small">(ไม่บังคับ)</span></label>
                                <input class="form-control" type="time" lang="en-GB"
                                       value="@_formBillingStart?.ToString("HH:mm")"
                                       @onchange="e => _formBillingStart = string.IsNullOrEmpty(e.Value?.ToString()) ? null : TimeOnly.Parse(e.Value!.ToString()!)" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">สิ้นสุดเก็บค่า</label>
                                <input class="form-control" type="time" lang="en-GB"
                                       value="@_formBillingEnd?.ToString("HH:mm")"
                                       @onchange="e => _formBillingEnd = string.IsNullOrEmpty(e.Value?.ToString()) ? null : TimeOnly.Parse(e.Value!.ToString()!)" />
                            </div>
                        }
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="formActive" @bind="_formIsActive" />
                                <label class="form-check-label" for="formActive">เปิดใช้งาน</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">ยกเลิก</button>
                    <button class="btn btn-primary" @onclick="SaveModalAsync">
                        @(_editingId.HasValue ? "บันทึกการแก้ไข" : "เพิ่มตารางเวลา")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid ParkingLotId { get; set; }

    private ParkingLot? _lot;
    private readonly List<ParkingLotSchedule> _schedules = [];
    private bool _isLoading = true;
    private bool _isLotLoaded;
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;

    private readonly (int bit, string label)[] _dayOptions =
    [
        (1, "จันทร์"), (2, "อังคาร"), (4, "พุธ"), (8, "พฤหัส"),
        (16, "ศุกร์"), (32, "เสาร์"), (64, "อาทิตย์")
    ];

    private bool _showModal;
    private Guid? _editingId;
    private string _formName = string.Empty;
    private int _formDays;
    private bool _formIsAllDay;
    private TimeOnly _formOpenTime = new(6, 0);
    private TimeOnly _formCloseTime = new(22, 0);
    private TimeOnly? _formBillingStart;
    private TimeOnly? _formBillingEnd;
    private bool _formIsActive = true;

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        if (!CurrentUserContext.IsAdmin) { _isLotLoaded = true; _isLoading = false; return; }
        ClearMessages();
        _isLoading = true; _isLotLoaded = false;
        try
        {
            var lots = await ParkingLotService.GetAllAsync();
            _lot = lots.FirstOrDefault(x => x.Id == ParkingLotId);
            _isLotLoaded = true;
            if (_lot is not null) await LoadSchedulesAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; _isLotLoaded = true; }
        finally { _isLoading = false; }
    }

    private async Task LoadSchedulesAsync()
    {
        _isLoading = true;
        try
        {
            var list = await ScheduleService.GetByLotIdAsync(ParkingLotId);
            _schedules.Clear();
            _schedules.AddRange(list);
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _isLoading = false; }
    }

    private void OpenAddModal()
    {
        ClearMessages();
        _editingId = null;
        _formName = string.Empty;
        _formDays = 0;
        _formIsAllDay = false;
        _formOpenTime = new(6, 0);
        _formCloseTime = new(22, 0);
        _formBillingStart = null;
        _formBillingEnd = null;
        _formIsActive = true;
        _showModal = true;
    }

    private void OpenEditModal(ParkingLotSchedule s)
    {
        ClearMessages();
        _editingId = s.Id;
        _formName = s.ScheduleName;
        _formDays = s.DaysOfWeek;
        _formIsAllDay = s.IsAllDay;
        _formOpenTime = TimeOnly.FromTimeSpan(s.OpenTime);
        _formCloseTime = TimeOnly.FromTimeSpan(s.CloseTime);
        _formBillingStart = s.BillingStartTime.HasValue ? TimeOnly.FromTimeSpan(s.BillingStartTime.Value) : null;
        _formBillingEnd = s.BillingEndTime.HasValue ? TimeOnly.FromTimeSpan(s.BillingEndTime.Value) : null;
        _formIsActive = s.IsActive;
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private void ToggleDay(int bit, bool on)
        => _formDays = on ? _formDays | bit : _formDays & ~bit;

    private async Task SaveModalAsync()
    {
        ClearMessages();
        if (string.IsNullOrWhiteSpace(_formName)) { _errorMessage = "กรุณากรอกชื่อตารางเวลา"; return; }
        try
        {
            var entity = new ParkingLotSchedule
            {
                Id = _editingId ?? Guid.Empty,
                ParkingLotId = ParkingLotId,
                ScheduleName = _formName.Trim(),
                DaysOfWeek = _formDays,
                IsAllDay = _formIsAllDay,
                OpenTime = _formOpenTime.ToTimeSpan(),
                CloseTime = _formCloseTime.ToTimeSpan(),
                BillingStartTime = _formBillingStart?.ToTimeSpan(),
                BillingEndTime = _formBillingEnd?.ToTimeSpan(),
                IsActive = _formIsActive
            };

            if (_editingId.HasValue)
            {
                await ScheduleService.UpdateAsync(entity);
                _successMessage = "แก้ไขตารางเวลาสำเร็จ";
            }
            else
            {
                await ScheduleService.CreateAsync(entity);
                _successMessage = "เพิ่มตารางเวลาสำเร็จ";
            }
            CloseModal();
            await LoadSchedulesAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    private async Task DeleteAsync(Guid id)
    {
        ClearMessages();
        try
        {
            await ScheduleService.DeleteAsync(id);
            _successMessage = "ลบตารางเวลาสำเร็จ";
            await LoadSchedulesAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    private void ClearMessages() { _errorMessage = string.Empty; _successMessage = string.Empty; }
}
