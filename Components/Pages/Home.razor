@page "/"
@inject CurrentUserContext CurrentUserContext

<PageTitle>หน้าหลัก</PageTitle>

<div class="view-head">
    <h1>ยินดีต้อนรับ</h1>
    <p class="view-subtitle">ระบบจัดการที่จอดรถ</p>
</div>

@if (!CurrentUserContext.IsAuthenticated)
{
    <div class="alert alert-info">
        กรุณา <a href="/login" class="alert-link">เข้าสู่ระบบ</a> เพื่อดำเนินการต่อ
    </div>
}
else if (CurrentUserContext.IsAdmin)
{
    <div class="row g-3">
        <div class="col-sm-6 col-lg-3">
            <a href="/parking-transaction" class="text-decoration-none">
                <div class="card h-100 border-primary">
                    <div class="card-body">
                        <h6 class="card-title text-primary">รายการจอดรถ</h6>
                        <p class="card-text text-muted small mb-0">บันทึกเข้า-ออก และคำนวณค่าจอด</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-3">
            <a href="/manage/parking-lot" class="text-decoration-none">
                <div class="card h-100 border-secondary">
                    <div class="card-body">
                        <h6 class="card-title text-secondary">จัดการลานจอดรถ</h6>
                        <p class="card-text text-muted small mb-0">ลาน ประตู ตารางเวลา อัตราค่าบริการ</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-3">
            <a href="/manage/parking-condition" class="text-decoration-none">
                <div class="card h-100 border-secondary">
                    <div class="card-body">
                        <h6 class="card-title text-secondary">เงื่อนไขจอดรถ</h6>
                        <p class="card-text text-muted small mb-0">สิทธิ์จอดฟรี โควต้า และเงื่อนไขพิเศษ</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-3">
            <a href="/report/parking-transaction" class="text-decoration-none">
                <div class="card h-100 border-secondary">
                    <div class="card-body">
                        <h6 class="card-title text-secondary">รายงาน</h6>
                        <p class="card-text text-muted small mb-0">ค้นหาและส่งออกข้อมูลจอดรถ</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        <div class="col-sm-6 col-lg-4">
            <a href="/parking-transaction" class="text-decoration-none">
                <div class="card h-100 border-primary">
                    <div class="card-body">
                        <h6 class="card-title text-primary">รายการจอดรถ</h6>
                        <p class="card-text text-muted small mb-0">บันทึกเข้า-ออก และคำนวณค่าจอด</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
}
