@page "/manage/parking-lot"
@inject CurrentUserContext CurrentUserContext
@inject ParkingLotService ParkingLotService
@inject ParkingConditionService ParkingConditionService
@using CarPark.Models
@using CarPark.Shared.Enums

<PageTitle>จัดการลานจอดรถ</PageTitle>

<div class="view-head">
    <h1>จัดการลานจอดรถ</h1>
    <p class="view-subtitle">ตั้งค่าลานจอดรถและดูรายละเอียดอัตราค่าบริการ</p>
</div>

@if (!CurrentUserContext.IsAdmin)
{
    <div class="alert alert-danger" role="alert">
        ไม่มีสิทธิ์เข้าใช้งาน หน้านี้สำหรับผู้ดูแลระบบเท่านั้น
    </div>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">เพิ่มลานจอดรถ</h5>

            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label" for="lotCode">รหัสลาน</label>
                    <input class="form-control" id="lotCode" @bind="_newLotCode" />
                </div>
                <div class="col-md-3">
                    <label class="form-label" for="lotName">ชื่อลาน</label>
                    <input class="form-control" id="lotName" @bind="_newLotName" />
                </div>
                <div class="col-md-2">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" id="newAllDay" @bind="_newLotIsAllDay" />
                        <label class="form-check-label" for="newAllDay">เปิดตลอดเวลา</label>
                    </div>
                </div>
                @if (!_newLotIsAllDay)
                {
                    <div class="col-md-1">
                        <label class="form-label">เปิด</label>
                        <input class="form-control" type="time" @bind="_newLotOpenTime" />
                    </div>
                    <div class="col-md-1">
                        <label class="form-label">ปิด</label>
                        <input class="form-control" type="time" @bind="_newLotCloseTime" />
                    </div>
                    <div class="col-md-1">
                        <label class="form-label">เก็บค่าเริ่ม <small class="text-muted">(ไม่บังคับ)</small></label>
                        <input class="form-control" type="time" value="@_newLotBillingStart?.ToString("HH:mm")"
                               @onchange="e => _newLotBillingStart = string.IsNullOrEmpty(e.Value?.ToString()) ? null : TimeOnly.Parse(e.Value!.ToString()!)" />
                    </div>
                    <div class="col-md-1">
                        <label class="form-label">เก็บค่าสิ้นสุด</label>
                        <input class="form-control" type="time" value="@_newLotBillingEnd?.ToString("HH:mm")"
                               @onchange="e => _newLotBillingEnd = string.IsNullOrEmpty(e.Value?.ToString()) ? null : TimeOnly.Parse(e.Value!.ToString()!)" />
                    </div>
                }
                <div class="col-md-2">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" id="newHasOvernight" @bind="_newLotHasOvernightPenalty" />
                        <label class="form-check-label" for="newHasOvernight">ค่าปรับข้ามคืน</label>
                    </div>
                </div>
                @if (_newLotHasOvernightPenalty)
                {
                    <div class="col-md-2">
                        <label class="form-label">จำนวนเงิน</label>
                        <input class="form-control" type="number" min="0" step="0.01" @bind="_newLotOvernightPenaltyAmount" />
                    </div>
                }
                <div class="col-md-1">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" id="lotActive" @bind="_newLotIsActive" />
                        <label class="form-check-label" for="lotActive">ใช้งาน</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary w-100" @onclick="AddLotAsync">เพิ่ม</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">คัดลอกการตั้งค่าลาน</h5>
            <p class="text-muted small mb-2">คัดลอกเวลาทำการ ค่าปรับข้ามคืน ตารางเวลา และอัตราค่าบริการทั้งหมดจากลานต้นทางไปยังลานปลายทาง (ข้อมูลเดิมของลานปลายทางจะถูกแทนที่)</p>
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">ลานต้นทาง</label>
                    <select class="form-select" @bind="_copySourceLotId">
                        <option value="">-- เลือกลานต้นทาง --</option>
                        @foreach (var lot in _lots)
                        {
                            <option value="@lot.Id">@lot.LotCode - @lot.LotName</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">ลานปลายทาง</label>
                    <select class="form-select" @bind="_copyTargetLotId">
                        <option value="">-- เลือกลานปลายทาง --</option>
                        @foreach (var lot in _lots)
                        {
                            <option value="@lot.Id">@lot.LotCode - @lot.LotName</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-secondary w-100"
                            @onclick="CopyLotAsync"
                            disabled="@(string.IsNullOrWhiteSpace(_copySourceLotId) || string.IsNullOrWhiteSpace(_copyTargetLotId))">
                        คัดลอก
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h5 class="card-title">รายการลานจอดรถ</h5>

            @if (_isLoading)
            {
                <p>กำลังโหลด...</p>
            }
            else if (_lots.Count == 0)
            {
                <p>ไม่พบรายการลานจอดรถ</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>รหัสลาน</th>
                                <th>ชื่อลาน</th>
                                <th>เวลาทำการ</th>
                                <th>ค่าปรับข้ามคืน</th>
                                <th>ใช้งาน</th>
                                <th class="text-end">จัดการ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lot in _lots)
                            {
                                <tr>
                                    @if (_editingLotId == lot.Id)
                                    {
                                        <td><input class="form-control" @bind="_editLotCode" /></td>
                                        <td><input class="form-control" @bind="_editLotName" /></td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                                <div class="form-check mb-0">
                                                    <input class="form-check-input" type="checkbox" id="editAllDay_@lot.Id" @bind="_editLotIsAllDay" />
                                                    <label class="form-check-label" for="editAllDay_@lot.Id">ตลอดเวลา</label>
                                                </div>
                                                @if (!_editLotIsAllDay)
                                                {
                                                    <div class="d-flex flex-column gap-1">
                                                        <div class="d-flex align-items-center gap-1">
                                                            <small class="text-muted" style="width:58px">ทำการ</small>
                                                            <input class="form-control form-control-sm" type="time" style="width:100px" @bind="_editLotOpenTime" />
                                                            <span>-</span>
                                                            <input class="form-control form-control-sm" type="time" style="width:100px" @bind="_editLotCloseTime" />
                                                        </div>
                                                        <div class="d-flex align-items-center gap-1">
                                                            <small class="text-muted" style="width:58px">เก็บค่า</small>
                                                            <input class="form-control form-control-sm" type="time" style="width:100px"
                                                                   value="@_editLotBillingStart?.ToString("HH:mm")"
                                                                   @onchange="e => _editLotBillingStart = string.IsNullOrEmpty(e.Value?.ToString()) ? null : TimeOnly.Parse(e.Value!.ToString()!)" />
                                                            <span>-</span>
                                                            <input class="form-control form-control-sm" type="time" style="width:100px"
                                                                   value="@_editLotBillingEnd?.ToString("HH:mm")"
                                                                   @onchange="e => _editLotBillingEnd = string.IsNullOrEmpty(e.Value?.ToString()) ? null : TimeOnly.Parse(e.Value!.ToString()!)" />
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="form-check mb-0">
                                                    <input class="form-check-input" type="checkbox" id="editHasOvernight_@lot.Id" @bind="_editLotHasOvernightPenalty" />
                                                    <label class="form-check-label" for="editHasOvernight_@lot.Id">มี</label>
                                                </div>
                                                @if (_editLotHasOvernightPenalty)
                                                {
                                                    <input class="form-control form-control-sm" type="number" min="0" step="0.01" style="width:100px" @bind="_editLotOvernightPenaltyAmount" />
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <input class="form-check-input" type="checkbox" @bind="_editLotIsActive" />
                                        </td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-success me-2" @onclick="SaveEditAsync">บันทึก</button>
                                            <button class="btn btn-sm btn-secondary" @onclick="CancelEdit">ยกเลิก</button>
                                        </td>
                                    }
                                    else
                                    {
                                        <td>@lot.LotCode</td>
                                        <td>@lot.LotName</td>
                                        <td>
                                            @if (lot.IsAllDay)
                                            {
                                                <span class="badge bg-info text-dark">ตลอดเวลา</span>
                                            }
                                            else
                                            {
                                                <div>
                                                    <div><small class="text-muted">ทำการ</small> @lot.OpenTime.ToString(@"hh\:mm") - @lot.CloseTime.ToString(@"hh\:mm")</div>
                                                    @if (lot.BillingStartTime.HasValue && lot.BillingEndTime.HasValue)
                                                    {
                                                        <div><small class="text-muted">เก็บค่า</small> @lot.BillingStartTime.Value.ToString(@"hh\:mm") - @lot.BillingEndTime.Value.ToString(@"hh\:mm")</div>
                                                    }
                                                </div>
                                            }
                                        </td>
                                        <td>
                                            @if (lot.HasOvernightPenalty)
                                            {
                                                <span class="badge bg-warning text-dark">@lot.OvernightPenaltyAmount.ToString("N0") ฿</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>@(lot.IsActive ? "ใช้งาน" : "ปิดใช้งาน")</td>
                                        <td class="text-end">
                                            <a class="btn btn-sm btn-outline-secondary me-2" href="@($"/manage/parking-lot/{lot.Id}/gates")">ประตู</a>
                                            <a class="btn btn-sm btn-outline-info me-2" href="@($"/manage/parking-lot/{lot.Id}/schedules")">ตารางเวลา</a>
                                            <a class="btn btn-sm btn-outline-dark me-2" href="@($"/manage/parking-lot/{lot.Id}/rate-rules")">อัตราค่าบริการ</a>
                                            <button class="btn btn-sm btn-outline-success me-2" @onclick="@(() => OpenConditionModalAsync(lot))">เงื่อนไข</button>
                                            <button class="btn btn-sm btn-outline-primary me-2" @onclick="@(() => StartEdit(lot))">แก้ไข</button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="@(() => DeleteLotAsync(lot.Id))">ลบ</button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert alert-danger mt-3" role="alert">
            @_errorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success mt-3" role="alert">
            @_successMessage
        </div>
    }
}

@if (_conditionModalLotId.HasValue)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">ผูกเงื่อนไขจอดรถ — @_conditionModalLotName</h5>
                    <button type="button" class="btn-close" @onclick="CloseConditionModal"></button>
                </div>
                <div class="modal-body">
                    @if (_conditionModalConditions.Count == 0)
                    {
                        <p class="text-muted">ไม่มีเงื่อนไขที่ต้องผูกกับลาน (ทุกเงื่อนไขใช้ได้ทุกลานอยู่แล้ว)</p>
                    }
                    else
                    {
                        <p class="text-muted small mb-2">เลือกเงื่อนไขที่ใช้ได้กับลานนี้ (เฉพาะที่ตั้งค่า "ไม่ใช้ได้ทุกลาน")</p>
                        @foreach (var cond in _conditionModalConditions)
                        {
                            var condId = cond.Id;
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="cond_@condId"
                                       checked="@_conditionSelectedIds.Contains(condId)"
                                       @onchange="e => ToggleCondition(condId, (bool)(e.Value ?? false))" />
                                <label class="form-check-label" for="cond_@condId">
                                    @cond.ConditionName
                                    <span class="text-muted small ms-1">(@GetTypeName(cond.ConditionType))</span>
                                </label>
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseConditionModal">ยกเลิก</button>
                    <button class="btn btn-primary" @onclick="SaveLotConditionsAsync">บันทึก</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private readonly List<ParkingLot> _lots = [];
    private bool _isLoading = true;

    private string _newLotCode = string.Empty;
    private string _newLotName = string.Empty;
    private bool _newLotIsAllDay = true;
    private TimeOnly _newLotOpenTime = new(6, 0);
    private TimeOnly _newLotCloseTime = new(22, 0);
    private TimeOnly? _newLotBillingStart;
    private TimeOnly? _newLotBillingEnd;
    private bool _newLotHasOvernightPenalty;
    private decimal _newLotOvernightPenaltyAmount;
    private bool _newLotIsActive = true;

    private Guid? _editingLotId;
    private string _editLotCode = string.Empty;
    private string _editLotName = string.Empty;
    private bool _editLotIsAllDay = true;
    private TimeOnly _editLotOpenTime = new(6, 0);
    private TimeOnly _editLotCloseTime = new(22, 0);
    private TimeOnly? _editLotBillingStart;
    private TimeOnly? _editLotBillingEnd;
    private bool _editLotHasOvernightPenalty;
    private decimal _editLotOvernightPenaltyAmount;
    private bool _editLotIsActive;

    private string _copySourceLotId = string.Empty;
    private string _copyTargetLotId = string.Empty;

    private Guid? _conditionModalLotId;
    private string _conditionModalLotName = string.Empty;
    private List<ParkingCondition> _conditionModalConditions = [];
    private HashSet<Guid> _conditionSelectedIds = [];

    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadLotsAsync();
    }

    private async Task LoadLotsAsync()
    {
        if (!CurrentUserContext.IsAdmin)
        {
            _isLoading = false;
            return;
        }

        _isLoading = true;
        _errorMessage = string.Empty;

        try
        {
            var lots = await ParkingLotService.GetAllAsync();
            _lots.Clear();
            _lots.AddRange(lots);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task AddLotAsync()
    {
        ClearMessages();

        if (!ValidateLot(_newLotCode, _newLotName))
        {
            return;
        }

        try
        {
            await ParkingLotService.CreateAsync(new ParkingLot
            {
                LotCode = _newLotCode,
                LotName = _newLotName,
                IsAllDay = _newLotIsAllDay,
                OpenTime = _newLotOpenTime.ToTimeSpan(),
                CloseTime = _newLotCloseTime.ToTimeSpan(),
                BillingStartTime = _newLotBillingStart?.ToTimeSpan(),
                BillingEndTime = _newLotBillingEnd?.ToTimeSpan(),
                HasOvernightPenalty = _newLotHasOvernightPenalty,
                OvernightPenaltyAmount = _newLotOvernightPenaltyAmount,
                IsActive = _newLotIsActive
            });

            _newLotCode = string.Empty;
            _newLotName = string.Empty;
            _newLotIsAllDay = true;
            _newLotOpenTime = new(6, 0);
            _newLotCloseTime = new(22, 0);
            _newLotBillingStart = null;
            _newLotBillingEnd = null;
            _newLotHasOvernightPenalty = false;
            _newLotOvernightPenaltyAmount = 0;
            _newLotIsActive = true;
            _successMessage = "เพิ่มลานจอดรถสำเร็จ";

            await LoadLotsAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void StartEdit(ParkingLot lot)
    {
        ClearMessages();
        _editingLotId = lot.Id;
        _editLotCode = lot.LotCode;
        _editLotName = lot.LotName;
        _editLotIsAllDay = lot.IsAllDay;
        _editLotOpenTime = TimeOnly.FromTimeSpan(lot.OpenTime);
        _editLotCloseTime = TimeOnly.FromTimeSpan(lot.CloseTime);
        _editLotBillingStart = lot.BillingStartTime.HasValue ? TimeOnly.FromTimeSpan(lot.BillingStartTime.Value) : null;
        _editLotBillingEnd = lot.BillingEndTime.HasValue ? TimeOnly.FromTimeSpan(lot.BillingEndTime.Value) : null;
        _editLotHasOvernightPenalty = lot.HasOvernightPenalty;
        _editLotOvernightPenaltyAmount = lot.OvernightPenaltyAmount;
        _editLotIsActive = lot.IsActive;
    }

    private void CancelEdit()
    {
        _editingLotId = null;
        _editLotCode = string.Empty;
        _editLotName = string.Empty;
        _editLotIsAllDay = true;
        _editLotOpenTime = new(6, 0);
        _editLotCloseTime = new(22, 0);
        _editLotBillingStart = null;
        _editLotBillingEnd = null;
        _editLotHasOvernightPenalty = false;
        _editLotOvernightPenaltyAmount = 0;
        _editLotIsActive = false;
    }

    private async Task SaveEditAsync()
    {
        ClearMessages();

        if (_editingLotId is null)
        {
            return;
        }

        if (!ValidateLot(_editLotCode, _editLotName))
        {
            return;
        }

        try
        {
            await ParkingLotService.UpdateAsync(new ParkingLot
            {
                Id = _editingLotId.Value,
                LotCode = _editLotCode,
                LotName = _editLotName,
                IsAllDay = _editLotIsAllDay,
                OpenTime = _editLotOpenTime.ToTimeSpan(),
                CloseTime = _editLotCloseTime.ToTimeSpan(),
                BillingStartTime = _editLotBillingStart?.ToTimeSpan(),
                BillingEndTime = _editLotBillingEnd?.ToTimeSpan(),
                HasOvernightPenalty = _editLotHasOvernightPenalty,
                OvernightPenaltyAmount = _editLotOvernightPenaltyAmount,
                IsActive = _editLotIsActive
            });

            _successMessage = "แก้ไขลานจอดรถสำเร็จ";
            CancelEdit();
            await LoadLotsAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task CopyLotAsync()
    {
        ClearMessages();

        if (!Guid.TryParse(_copySourceLotId, out var sourceId) || !Guid.TryParse(_copyTargetLotId, out var targetId))
        {
            _errorMessage = "กรุณาเลือกลานต้นทางและลานปลายทาง";
            return;
        }

        if (sourceId == targetId)
        {
            _errorMessage = "ต้นทางและปลายทางต้องไม่ใช่ลานเดียวกัน";
            return;
        }

        try
        {
            await ParkingLotService.CopyFromLotAsync(sourceId, targetId);
            _copySourceLotId = string.Empty;
            _copyTargetLotId = string.Empty;
            _successMessage = "คัดลอกการตั้งค่าลานสำเร็จ";
            await LoadLotsAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task DeleteLotAsync(Guid id)
    {
        ClearMessages();

        try
        {
            await ParkingLotService.DeleteAsync(id);
            _successMessage = "ลบลานจอดรถสำเร็จ";
            await LoadLotsAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private bool ValidateLot(string lotCode, string lotName)
    {
        if (string.IsNullOrWhiteSpace(lotCode))
        {
            _errorMessage = "กรุณากรอกรหัสลาน";
            return false;
        }

        if (string.IsNullOrWhiteSpace(lotName))
        {
            _errorMessage = "กรุณากรอกชื่อลาน";
            return false;
        }

        return true;
    }

    private async Task OpenConditionModalAsync(ParkingLot lot)
    {
        ClearMessages();
        _conditionModalLotId = lot.Id;
        _conditionModalLotName = lot.LotCode;
        var all = await ParkingConditionService.GetAllAsync();
        _conditionModalConditions = all.Where(c => c.IsActive).ToList();
        _conditionSelectedIds = await ParkingConditionService.GetLinkedConditionIdsAsync(lot.Id);
    }

    private void CloseConditionModal()
    {
        _conditionModalLotId = null;
        _conditionModalConditions = [];
        _conditionSelectedIds = [];
    }

    private void ToggleCondition(Guid condId, bool selected)
    {
        if (selected) _conditionSelectedIds.Add(condId);
        else _conditionSelectedIds.Remove(condId);
    }

    private async Task SaveLotConditionsAsync()
    {
        if (!_conditionModalLotId.HasValue) return;
        ClearMessages();
        try
        {
            await ParkingConditionService.UpdateLotConditionsAsync(_conditionModalLotId.Value, _conditionSelectedIds);
            _successMessage = "บันทึกเงื่อนไขสำเร็จ";
            CloseConditionModal();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private static string GetTypeName(ParkingConditionType type) => type switch
    {
        ParkingConditionType.FullyFree => "ฟรีทั้งหมด",
        ParkingConditionType.FreeFirstMinutes => "ฟรี N นาทีแรก",
        ParkingConditionType.QuotaFree => "ฟรีตามโควต้า",
        _ => "-"
    };

    private void ClearMessages()
    {
        _errorMessage = string.Empty;
        _successMessage = string.Empty;
    }
}
