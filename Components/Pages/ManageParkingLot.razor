@page "/manage/parking-lot"
@inject CurrentUserContext CurrentUserContext
@inject ParkingLotService ParkingLotService
@inject ParkingConditionService ParkingConditionService
@using CarPark.Models
@using CarPark.Shared.Enums

<PageTitle>จัดการลานจอดรถ</PageTitle>

<div class="view-head">
    <h1>จัดการลานจอดรถ</h1>
    <p class="view-subtitle">ตั้งค่าลานจอดรถและดูรายละเอียดอัตราค่าบริการ</p>
</div>

@if (!CurrentUserContext.IsAdmin)
{
    <div class="alert alert-danger" role="alert">
        ไม่มีสิทธิ์เข้าใช้งาน หน้านี้สำหรับผู้ดูแลระบบเท่านั้น
    </div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert alert-danger alert-dismissible mb-3" role="alert">
            @_errorMessage
            <button type="button" class="btn-close" @onclick="ClearMessages"></button>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success alert-dismissible mb-3" role="alert">
            @_successMessage
            <button type="button" class="btn-close" @onclick="ClearMessages"></button>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="card-title mb-0">รายการลานจอดรถ</h5>
                <button class="btn btn-primary" @onclick="OpenAddModal">+ เพิ่มลานจอดรถ</button>
            </div>

            @if (_isLoading)
            {
                <p class="text-muted">กำลังโหลด...</p>
            }
            else if (_lots.Count == 0)
            {
                <p class="text-muted">ยังไม่มีลานจอดรถ กดปุ่ม "เพิ่มลานจอดรถ" เพื่อเริ่มต้น</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ชื่อลาน</th>
                                <th>เวลาทำการ</th>
                                <th>ค่าปรับข้ามคืน</th>
                                <th>สถานะ</th>
                                <th>การตั้งค่า</th>
                                <th class="text-end"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lot in _lots)
                            {
                                <tr>
                                    <td class="fw-semibold">@lot.LotName</td>
                                    <td>
                                        @if (lot.IsAllDay)
                                        {
                                            <span class="badge bg-info text-dark">ตลอดเวลา</span>
                                        }
                                        else
                                        {
                                            <div class="small">
                                                <div>@lot.OpenTime.ToString(@"hh\:mm") – @lot.CloseTime.ToString(@"hh\:mm")</div>
                                                @if (lot.BillingStartTime.HasValue && lot.BillingEndTime.HasValue)
                                                {
                                                    <div class="text-muted">เก็บค่า @lot.BillingStartTime.Value.ToString(@"hh\:mm") – @lot.BillingEndTime.Value.ToString(@"hh\:mm")</div>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        @if (lot.HasOvernightPenalty)
                                        {
                                            <span class="badge bg-warning text-dark">@lot.OvernightPenaltyAmount.ToString("N0") ฿/คืน</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">ไม่มี</span>
                                        }
                                    </td>
                                    <td>
                                        @if (lot.IsActive)
                                        {
                                            <span class="badge bg-success">ใช้งาน</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">ปิด</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1 flex-wrap">
                                            <a class="btn btn-sm btn-outline-secondary" href="@($"/manage/parking-lot/{lot.Id}/gates")">ประตู</a>
                                            <a class="btn btn-sm btn-outline-secondary" href="@($"/manage/parking-lot/{lot.Id}/schedules")">ตาราง</a>
                                            <a class="btn btn-sm btn-outline-secondary" href="@($"/manage/parking-lot/{lot.Id}/rate-rules")">อัตราค่าบริการ</a>
                                            <button class="btn btn-sm btn-outline-teal" @onclick="@(() => OpenConditionModalAsync(lot))">เงื่อนไข</button>
                                        </div>
                                    </td>
                                    <td class="text-end" style="white-space:nowrap">
                                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="@(() => OpenEditModal(lot))">แก้ไข</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="@(() => DeleteLotAsync(lot.Id))">ลบ</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h5 class="card-title">คัดลอกการตั้งค่าลาน</h5>
            <p class="text-muted small mb-3">คัดลอกเวลาทำการ ค่าปรับข้ามคืน ตารางเวลา และอัตราค่าบริการทั้งหมดจากลานต้นทางไปยังลานปลายทาง (ข้อมูลเดิมของลานปลายทางจะถูกแทนที่)</p>
            <div class="row g-2 align-items-end">
                <div class="col-sm-5">
                    <label class="form-label">ลานต้นทาง</label>
                    <select class="form-select" @bind="_copySourceLotId">
                        <option value="">-- เลือกลานต้นทาง --</option>
                        @foreach (var lot in _lots)
                        {
                            <option value="@lot.Id">@lot.LotName</option>
                        }
                    </select>
                </div>
                <div class="col-sm-5">
                    <label class="form-label">ลานปลายทาง</label>
                    <select class="form-select" @bind="_copyTargetLotId">
                        <option value="">-- เลือกลานปลายทาง --</option>
                        @foreach (var lot in _lots)
                        {
                            <option value="@lot.Id">@lot.LotName</option>
                        }
                    </select>
                </div>
                <div class="col-sm-2">
                    <button class="btn btn-outline-secondary w-100"
                            @onclick="CopyLotAsync"
                            disabled="@(string.IsNullOrWhiteSpace(_copySourceLotId) || string.IsNullOrWhiteSpace(_copyTargetLotId))">
                        คัดลอก
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Add / Edit Modal ── *@
@if (_showLotModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editingLotId.HasValue ? "แก้ไขลานจอดรถ" : "เพิ่มลานจอดรถ")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">ชื่อลาน <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="_formLotName" placeholder="ชื่อเต็มของลาน" />
                        </div>

                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="formAllDay" @bind="_formIsAllDay" />
                                <label class="form-check-label" for="formAllDay">เปิดตลอดเวลา (24 ชม.)</label>
                            </div>
                        </div>

                        @if (!_formIsAllDay)
                        {
                            <div class="col-6">
                                <label class="form-label">เวลาเปิด</label>
                                <input class="form-control" type="time" lang="en-GB" @bind="_formOpenTime" @bind:format="HH:mm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">เวลาปิด</label>
                                <input class="form-control" type="time" lang="en-GB" @bind="_formCloseTime" @bind:format="HH:mm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">เริ่มเก็บค่า <span class="text-muted small">(ไม่บังคับ)</span></label>
                                <input class="form-control" type="time" lang="en-GB"
                                       value="@_formBillingStart?.ToString("HH:mm")"
                                       @onchange="e => _formBillingStart = string.IsNullOrEmpty(e.Value?.ToString()) ? null : TimeOnly.Parse(e.Value!.ToString()!)" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">สิ้นสุดเก็บค่า</label>
                                <input class="form-control" type="time" lang="en-GB"
                                       value="@_formBillingEnd?.ToString("HH:mm")"
                                       @onchange="e => _formBillingEnd = string.IsNullOrEmpty(e.Value?.ToString()) ? null : TimeOnly.Parse(e.Value!.ToString()!)" />
                            </div>
                        }

                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="formHasOvernight" @bind="_formHasOvernightPenalty" />
                                <label class="form-check-label" for="formHasOvernight">มีค่าปรับข้ามคืน</label>
                            </div>
                        </div>

                        @if (_formHasOvernightPenalty)
                        {
                            <div class="col-6">
                                <label class="form-label">จำนวนเงิน (บาท/คืน)</label>
                                <input class="form-control" type="number" min="0" step="0.01" @bind="_formOvernightPenaltyAmount" />
                            </div>
                        }

                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="formIsActive" @bind="_formIsActive" />
                                <label class="form-check-label" for="formIsActive">เปิดใช้งาน</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">ยกเลิก</button>
                    <button class="btn btn-primary" @onclick="SaveModalAsync">
                        @(_editingLotId.HasValue ? "บันทึกการแก้ไข" : "เพิ่มลาน")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Condition Modal ── *@
@if (_conditionModalLotId.HasValue)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">เงื่อนไขจอดรถ — @_conditionModalLotName</h5>
                    <button type="button" class="btn-close" @onclick="CloseConditionModal"></button>
                </div>
                <div class="modal-body">
                    @if (_conditionModalConditions.Count == 0)
                    {
                        <p class="text-muted mb-0">ไม่มีเงื่อนไขที่ใช้งานอยู่ในระบบ</p>
                    }
                    else
                    {
                        @foreach (var cond in _conditionModalConditions)
                        {
                            var condId = cond.Id;
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" id="cond_@condId"
                                       checked="@_conditionSelectedIds.Contains(condId)"
                                       @onchange="e => ToggleCondition(condId, (bool)(e.Value ?? false))" />
                                <label class="form-check-label" for="cond_@condId">
                                    @cond.ConditionName
                                    <span class="text-muted small ms-1">(@GetTypeName(cond.ConditionType))</span>
                                </label>
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseConditionModal">ยกเลิก</button>
                    <button class="btn btn-primary" @onclick="SaveLotConditionsAsync">บันทึก</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private readonly List<ParkingLot> _lots = [];
    private bool _isLoading = true;
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;

    // ── Lot Modal ──
    private bool _showLotModal;
    private Guid? _editingLotId;
    private string _formLotName = string.Empty;
    private bool _formIsAllDay = true;
    private TimeOnly _formOpenTime = new(6, 0);
    private TimeOnly _formCloseTime = new(22, 0);
    private TimeOnly? _formBillingStart;
    private TimeOnly? _formBillingEnd;
    private bool _formHasOvernightPenalty;
    private decimal _formOvernightPenaltyAmount;
    private bool _formIsActive = true;

    // ── Copy ──
    private string _copySourceLotId = string.Empty;
    private string _copyTargetLotId = string.Empty;

    // ── Condition Modal ──
    private Guid? _conditionModalLotId;
    private string _conditionModalLotName = string.Empty;
    private List<ParkingCondition> _conditionModalConditions = [];
    private HashSet<Guid> _conditionSelectedIds = [];

    protected override async Task OnInitializedAsync() => await LoadLotsAsync();

    private async Task LoadLotsAsync()
    {
        if (!CurrentUserContext.IsAdmin) { _isLoading = false; return; }

        _isLoading = true;
        try
        {
            var lots = await ParkingLotService.GetAllAsync();
            _lots.Clear();
            _lots.AddRange(lots);
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
        finally { _isLoading = false; }
    }

    // ── Modal helpers ──

    private void OpenAddModal()
    {
        ClearMessages();
        _editingLotId = null;
        _formLotName = string.Empty;
        _formIsAllDay = true;
        _formOpenTime = new(6, 0);
        _formCloseTime = new(22, 0);
        _formBillingStart = null;
        _formBillingEnd = null;
        _formHasOvernightPenalty = false;
        _formOvernightPenaltyAmount = 0;
        _formIsActive = true;
        _showLotModal = true;
    }

    private void OpenEditModal(ParkingLot lot)
    {
        ClearMessages();
        _editingLotId = lot.Id;
        _formLotName = lot.LotName;
        _formIsAllDay = lot.IsAllDay;
        _formOpenTime = TimeOnly.FromTimeSpan(lot.OpenTime);
        _formCloseTime = TimeOnly.FromTimeSpan(lot.CloseTime);
        _formBillingStart = lot.BillingStartTime.HasValue ? TimeOnly.FromTimeSpan(lot.BillingStartTime.Value) : null;
        _formBillingEnd = lot.BillingEndTime.HasValue ? TimeOnly.FromTimeSpan(lot.BillingEndTime.Value) : null;
        _formHasOvernightPenalty = lot.HasOvernightPenalty;
        _formOvernightPenaltyAmount = lot.OvernightPenaltyAmount;
        _formIsActive = lot.IsActive;
        _showLotModal = true;
    }

    private void CloseModal() => _showLotModal = false;

    private async Task SaveModalAsync()
    {
        ClearMessages();

        if (string.IsNullOrWhiteSpace(_formLotName)) { _errorMessage = "กรุณากรอกชื่อลาน"; return; }

        try
        {
            var entity = new ParkingLot
            {
                Id = _editingLotId ?? Guid.Empty,
                LotName = _formLotName.Trim(),
                IsAllDay = _formIsAllDay,
                OpenTime = _formOpenTime.ToTimeSpan(),
                CloseTime = _formCloseTime.ToTimeSpan(),
                BillingStartTime = _formBillingStart?.ToTimeSpan(),
                BillingEndTime = _formBillingEnd?.ToTimeSpan(),
                HasOvernightPenalty = _formHasOvernightPenalty,
                OvernightPenaltyAmount = _formOvernightPenaltyAmount,
                IsActive = _formIsActive
            };

            if (_editingLotId.HasValue)
            {
                await ParkingLotService.UpdateAsync(entity);
                _successMessage = "แก้ไขลานจอดรถสำเร็จ";
            }
            else
            {
                await ParkingLotService.CreateAsync(entity);
                _successMessage = "เพิ่มลานจอดรถสำเร็จ";
            }

            CloseModal();
            await LoadLotsAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    // ── Delete / Copy ──

    private async Task DeleteLotAsync(Guid id)
    {
        ClearMessages();
        try
        {
            await ParkingLotService.DeleteAsync(id);
            _successMessage = "ลบลานจอดรถสำเร็จ";
            await LoadLotsAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    private async Task CopyLotAsync()
    {
        ClearMessages();

        if (!Guid.TryParse(_copySourceLotId, out var sourceId) || !Guid.TryParse(_copyTargetLotId, out var targetId))
        {
            _errorMessage = "กรุณาเลือกลานต้นทางและลานปลายทาง";
            return;
        }

        if (sourceId == targetId) { _errorMessage = "ต้นทางและปลายทางต้องไม่ใช่ลานเดียวกัน"; return; }

        try
        {
            await ParkingLotService.CopyFromLotAsync(sourceId, targetId);
            _copySourceLotId = string.Empty;
            _copyTargetLotId = string.Empty;
            _successMessage = "คัดลอกการตั้งค่าลานสำเร็จ";
            await LoadLotsAsync();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    // ── Condition Modal ──

    private async Task OpenConditionModalAsync(ParkingLot lot)
    {
        ClearMessages();
        _conditionModalLotId = lot.Id;
        _conditionModalLotName = lot.LotName;
        var all = await ParkingConditionService.GetAllAsync();
        _conditionModalConditions = all.Where(c => c.IsActive).ToList();
        _conditionSelectedIds = await ParkingConditionService.GetLinkedConditionIdsAsync(lot.Id);
    }

    private void CloseConditionModal()
    {
        _conditionModalLotId = null;
        _conditionModalConditions = [];
        _conditionSelectedIds = [];
    }

    private void ToggleCondition(Guid condId, bool selected)
    {
        if (selected) _conditionSelectedIds.Add(condId);
        else _conditionSelectedIds.Remove(condId);
    }

    private async Task SaveLotConditionsAsync()
    {
        if (!_conditionModalLotId.HasValue) return;
        ClearMessages();
        try
        {
            await ParkingConditionService.UpdateLotConditionsAsync(_conditionModalLotId.Value, _conditionSelectedIds);
            _successMessage = "บันทึกเงื่อนไขสำเร็จ";
            CloseConditionModal();
        }
        catch (Exception ex) { _errorMessage = ex.Message; }
    }

    private static string GetTypeName(ParkingConditionType type) => type switch
    {
        ParkingConditionType.FullyFree => "ฟรีทั้งหมด",
        ParkingConditionType.FreeFirstMinutes => "ฟรี N นาทีแรก",
        ParkingConditionType.QuotaFree => "ฟรีตามโควต้า",
        _ => "-"
    };

    private void ClearMessages()
    {
        _errorMessage = string.Empty;
        _successMessage = string.Empty;
    }
}
