@page "/change-password"
@inject CurrentUserContext CurrentUserContext
@inject UserAuthService UserAuthService
@inject NavigationManager NavigationManager

<PageTitle>เปลี่ยนรหัสผ่าน</PageTitle>

<div class="view-head">
    <h1>เปลี่ยนรหัสผ่าน</h1>
    <p class="view-subtitle">อัปเดตรหัสผ่านเพื่อความปลอดภัยของบัญชี</p>
</div>

@if (!CurrentUserContext.IsAuthenticated)
{
    <div class="alert alert-danger" role="alert">
        กรุณาเข้าสู่ระบบก่อน
    </div>
}
else
{
    @if (CurrentUserContext.MustChangePassword)
    {
        <div class="alert alert-warning" role="alert">
            คุณต้องเปลี่ยนรหัสผ่านก่อนใช้งานหน้าอื่น
        </div>
    }

    <div class="card">
        <div class="card-body">
            <div class="row g-2">
                <div class="col-12">
                    <label class="form-label">รหัสผ่านปัจจุบัน</label>
                    <input class="form-control" type="password" @bind="_currentPassword" />
                </div>
                <div class="col-12">
                    <label class="form-label">รหัสผ่านใหม่</label>
                    <input class="form-control" type="password" @bind="_newPassword" />
                </div>
                <div class="col-12">
                    <label class="form-label">ยืนยันรหัสผ่านใหม่</label>
                    <input class="form-control" type="password" @bind="_confirmPassword" />
                </div>
                <div class="col-12 d-flex justify-content-end gap-2 mt-2">
                    @if (!CurrentUserContext.MustChangePassword)
                    {
                        <a class="btn btn-outline-secondary" href="/">ยกเลิก</a>
                    }
                    <button class="btn btn-primary" @onclick="ChangePasswordAsync">บันทึกรหัสผ่าน</button>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert alert-danger mt-3" role="alert">@_errorMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success mt-3" role="alert">@_successMessage</div>
    }
}

@code {
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;

    private async Task ChangePasswordAsync()
    {
        _errorMessage = string.Empty;
        _successMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(_currentPassword)
            || string.IsNullOrWhiteSpace(_newPassword)
            || string.IsNullOrWhiteSpace(_confirmPassword))
        {
            _errorMessage = "กรุณากรอกข้อมูลรหัสผ่านให้ครบ";
            return;
        }

        if (!string.Equals(_newPassword, _confirmPassword, StringComparison.Ordinal))
        {
            _errorMessage = "รหัสผ่านใหม่และการยืนยันไม่ตรงกัน";
            return;
        }

        try
        {
            await UserAuthService.ChangePasswordAsync(_currentPassword, _newPassword);
            _currentPassword = string.Empty;
            _newPassword = string.Empty;
            _confirmPassword = string.Empty;
            _successMessage = "เปลี่ยนรหัสผ่านสำเร็จ";

            NavigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }
}
