@page "/manage/user"
@inject CurrentUserContext CurrentUserContext
@inject UserService UserService

<PageTitle>จัดการผู้ใช้</PageTitle>

<div class="view-head">
    <h1>จัดการผู้ใช้</h1>
    <p class="view-subtitle">สร้าง แก้ไข และกำหนดสิทธิ์การเข้าใช้งานสำหรับผู้ใช้</p>
</div>

@if (!CurrentUserContext.IsAdmin)
{
    <div class="alert alert-danger" role="alert">
        ไม่มีสิทธิ์เข้าใช้งาน หน้านี้สำหรับผู้ดูแลระบบเท่านั้น
    </div>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">เพิ่มผู้ใช้</h5>

            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">ชื่อผู้ใช้</label>
                    <input class="form-control" @bind="_newUsername" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">ชื่อ-นามสกุล</label>
                    <input class="form-control" @bind="_newName" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">รหัสผ่าน</label>
                    <input class="form-control" type="password" @bind="_newPassword" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">บทบาท</label>
                    <select class="form-select" @bind="_newRole">
                        @foreach (var role in _roles)
                        {
                            <option value="@role">@role</option>
                        }
                    </select>
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button class="btn btn-primary w-100" @onclick="AddUserAsync">เพิ่ม</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h5 class="card-title">รายการผู้ใช้</h5>

            @if (_isLoading)
            {
                <p>กำลังโหลด...</p>
            }
            else if (_users.Count == 0)
            {
                <p>ไม่พบรายการผู้ใช้</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>ชื่อผู้ใช้</th>
                                <th>ชื่อ-นามสกุล</th>
                                <th>บทบาท</th>
                                <th class="text-end">จัดการ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in _users)
                            {
                                <tr>
                                    @if (_editingUserId == user.Id)
                                    {
                                        <td><input class="form-control" @bind="_editUsername" /></td>
                                        <td><input class="form-control" @bind="_editName" /></td>
                                        <td>
                                            <select class="form-select" @bind="_editRole">
                                                @foreach (var role in _roles)
                                                {
                                                    <option value="@role">@role</option>
                                                }
                                            </select>
                                        </td>
                                        <td class="text-end">
                                            <input class="form-control mb-2" type="password" placeholder="รหัสผ่านใหม่ (ไม่บังคับ)" @bind="_editPassword" />
                                            <button class="btn btn-sm btn-success me-2" @onclick="SaveEditAsync">บันทึก</button>
                                            <button class="btn btn-sm btn-secondary" @onclick="CancelEdit">ยกเลิก</button>
                                        </td>
                                    }
                                    else
                                    {
                                        <td>@user.Username</td>
                                        <td>@user.Name</td>
                                        <td>@user.Role</td>
                                        <td class="text-end">
                                            <button class="btn btn-sm btn-outline-primary me-2" @onclick="@(() => StartEdit(user))">แก้ไข</button>
                                            @if (user.Id != CurrentUserContext.CurrentUserId)
                                            {
                                                <button class="btn btn-sm btn-outline-danger" @onclick="@(() => DeleteUserAsync(user.Id))">ลบ</button>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert alert-danger mt-3" role="alert">
            @_errorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success mt-3" role="alert">
            @_successMessage
        </div>
    }
}

@code {
    private readonly List<User> _users = [];
    private readonly Role[] _roles = Enum.GetValues<Role>();

    private bool _isLoading = true;
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;

    private string _newUsername = string.Empty;
    private string _newName = string.Empty;
    private string _newPassword = string.Empty;
    private Role _newRole = Role.User;

    private Guid? _editingUserId;
    private string _editUsername = string.Empty;
    private string _editName = string.Empty;
    private string _editPassword = string.Empty;
    private Role _editRole = Role.User;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        if (!CurrentUserContext.IsAdmin)
        {
            _isLoading = false;
            return;
        }

        _isLoading = true;
        _errorMessage = string.Empty;

        try
        {
            _users.Clear();
            _users.AddRange(await UserService.GetAllAsync());
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task AddUserAsync()
    {
        ClearMessages();

        if (string.IsNullOrWhiteSpace(_newUsername) || string.IsNullOrWhiteSpace(_newName) || string.IsNullOrWhiteSpace(_newPassword))
        {
            _errorMessage = "กรุณากรอกชื่อผู้ใช้ ชื่อ-นามสกุล และรหัสผ่าน";
            return;
        }

        try
        {
            await UserService.CreateAsync(new User
            {
                Username = _newUsername,
                Name = _newName,
                Password = _newPassword,
                Role = _newRole
            });

            _newUsername = string.Empty;
            _newName = string.Empty;
            _newPassword = string.Empty;
            _newRole = Role.User;
            _successMessage = "เพิ่มผู้ใช้สำเร็จ";
            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void StartEdit(User user)
    {
        ClearMessages();
        _editingUserId = user.Id;
        _editUsername = user.Username;
        _editName = user.Name;
        _editRole = user.Role;
        _editPassword = string.Empty;
    }

    private void CancelEdit()
    {
        _editingUserId = null;
        _editUsername = string.Empty;
        _editName = string.Empty;
        _editPassword = string.Empty;
        _editRole = Role.User;
    }

    private async Task SaveEditAsync()
    {
        ClearMessages();

        if (!_editingUserId.HasValue)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_editUsername) || string.IsNullOrWhiteSpace(_editName))
        {
            _errorMessage = "กรุณากรอกชื่อผู้ใช้และชื่อ-นามสกุล";
            return;
        }

        try
        {
            await UserService.UpdateAsync(
                new User
                {
                    Id = _editingUserId.Value,
                    Username = _editUsername,
                    Name = _editName,
                    Role = _editRole
                },
                _editPassword);

            _successMessage = "แก้ไขผู้ใช้สำเร็จ";
            CancelEdit();
            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task DeleteUserAsync(Guid userId)
    {
        ClearMessages();

        try
        {
            await UserService.DeleteAsync(userId);
            _successMessage = "ลบผู้ใช้สำเร็จ";
            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void ClearMessages()
    {
        _errorMessage = string.Empty;
        _successMessage = string.Empty;
    }
}
