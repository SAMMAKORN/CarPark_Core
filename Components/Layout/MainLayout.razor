@inherits LayoutComponentBase
@inject CurrentUserContext CurrentUserContext
@inject DatabaseHealthService DatabaseHealthService
@implements IDisposable

@if (!DatabaseHealthService.IsConnected)
{
    <div class="db-offline-banner">
        <span>ไม่สามารถเชื่อมต่อฐานข้อมูลได้ — ระบบอาจทำงานไม่ถูกต้อง กรุณาตรวจสอบการเชื่อมต่อ</span>
    </div>
}

<div class="page @(CurrentUserContext.IsAuthenticated ? "layout-auth" : "layout-guest")">
    @if (CurrentUserContext.IsAuthenticated)
    {
        <div class="sidebar">
            <NavMenu />
        </div>
    }

    <main class="app-main">
        @if (CurrentUserContext.IsAuthenticated)
        {
            <div class="top-row app-top px-4">
                <div class="top-row-left">
                    <div class="top-row-title">ศูนย์ควบคุมการจอดรถ</div>
                </div>
                @if (CurrentUserContext.CurrentParkingLot is not null)
                {
                    <div class="top-row-lot">
                        <span class="top-lot-dot"></span>
                        <span class="top-lot-name">@CurrentUserContext.CurrentParkingLot.LotName</span>
                        @if (CurrentUserContext.CurrentGate is not null)
                        {
                            <span class="top-lot-sep">·</span>
                            <span class="top-lot-gate">@CurrentUserContext.CurrentGate.GateName</span>
                        }
                    </div>
                }
            </div>
        }

        <article class="content px-4 @(CurrentUserContext.IsAuthenticated ? "app-content" : "auth-content")">
            @Body
        </article>
    </main>
</div>

@code {
    protected override void OnInitialized()
    {
        DatabaseHealthService.OnStatusChanged += OnDbStatusChanged;
    }

    private void OnDbStatusChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DatabaseHealthService.OnStatusChanged -= OnDbStatusChanged;
    }
}
